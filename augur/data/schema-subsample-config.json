{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://nextstrain.org/schemas/augur/subsample-config",
    "title": "Configuration file to be supplied to `augur subsample --config`",
    "type": "object",
    "additionalProperties": false,
    "required": ["samples"],
    "properties": {
        "include": {
            "type": "array",
            "items": {"type": "string"}
        },
        "include_where": {
            "type": "array",
            "items": {"type": "string"}
        },
        "samples": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "exclude": {
                        "type": "array",
                        "items": {"type": "string"}
                    },
                    "exclude_all": {
                        "type": "boolean"
                    },
                    "exclude_ambiguous_dates_by": {
                        "type": "string",
                        "enum": ["any", "day", "month", "year"]
                    },
                    "exclude_where": {
                        "type": "array",
                        "items": {"type": "string"}
                    },
                    "group_by": {
                        "type": "array",
                        "items": {"type": "string"},
                        "minItems": 1
                    },
                    "group_by_weights": {"type": "string"},
                    "max_date": {"type": "string"},
                    "max_length": {"type": "integer"},
                    "min_date": {"type": "string"},
                    "min_length": {"type": "integer"},
                    "non_nucleotide": {"type": "boolean"},
                    "probabilistic_sampling": {"type": "boolean"},
                    "query": {"type": "string"},
                    "query_columns": {
                        "type": "array",
                        "items": {"type": "string"}
                    },
                    "sequences_per_group": {"type": "integer"},
                    "subsample_max_sequences": {"type": "integer"}
                },
                "oneOf": [
                    { "required": ["subsample_max_sequences"], "not": { "required": ["sequences_per_group"] } },
                    { "required": ["sequences_per_group"], "not": { "required": ["subsample_max_sequences"] } }
                ]
            }
        }
    }
}
